<UserControl x:Class="WPFBase.Views.ModernValidationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFBase.Views"
             xmlns:controls="clr-namespace:WPFBase.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <TextBlock Grid.Row="0" 
                  Text="Validation Example" 
                  FontSize="24" 
                  FontWeight="Bold" 
                  Margin="0,0,0,20"/>
        
        <!-- Validation Summary -->
        <controls:ValidationSummary Grid.Row="1" 
                                   DataContext="{Binding}" 
                                   Margin="0,0,0,20"/>
        
        <!-- Form -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Email Field -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Email Address:" FontWeight="Bold"/>
                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                            Style="{StaticResource ValidatedTextBox}"
                            Width="300" 
                            HorizontalAlignment="Left"/>
                </StackPanel>
                
                <!-- Age Field -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Age:" FontWeight="Bold"/>
                    <TextBox Text="{Binding Age, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                            Style="{StaticResource ValidatedTextBox}"
                            Width="100" 
                            HorizontalAlignment="Left"/>
                </StackPanel>
                
                <!-- Password Field -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Password:" FontWeight="Bold"/>
                    <PasswordBox x:Name="PasswordField"
                                Style="{StaticResource ValidatedPasswordBox}"
                                Width="300" 
                                HorizontalAlignment="Left"
                                PasswordChanged="PasswordField_PasswordChanged"/>
                </StackPanel>
                
                <!-- Confirm Password Field -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Confirm Password:" FontWeight="Bold"/>
                    <PasswordBox x:Name="ConfirmPasswordField"
                                Style="{StaticResource ValidatedPasswordBox}"
                                Width="300" 
                                HorizontalAlignment="Left"
                                PasswordChanged="ConfirmPasswordField_PasswordChanged"/>
                </StackPanel>
                
                <!-- First Name -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="First Name:" FontWeight="Bold"/>
                    <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                            Style="{StaticResource ValidatedTextBox}"
                            Width="200" 
                            HorizontalAlignment="Left"/>
                </StackPanel>
                
                <!-- Last Name -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Last Name:" FontWeight="Bold"/>
                    <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                            Style="{StaticResource ValidatedTextBox}"
                            Width="200" 
                            HorizontalAlignment="Left"/>
                </StackPanel>
                
                <!-- Country -->
                <StackPanel Margin="0,0,0,15">
                    <Label Content="Country:" FontWeight="Bold"/>
                    <ComboBox SelectedValue="{Binding Country, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                             Style="{StaticResource ValidatedComboBox}"
                             Width="200" 
                             HorizontalAlignment="Left">
                        <ComboBoxItem>United States</ComboBoxItem>
                        <ComboBoxItem>Canada</ComboBoxItem>
                        <ComboBoxItem>United Kingdom</ComboBoxItem>
                        <ComboBoxItem>Germany</ComboBoxItem>
                        <ComboBoxItem>France</ComboBoxItem>
                        <ComboBoxItem>Other</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                
                <!-- Terms and Conditions -->
                <CheckBox Content="I agree to the Terms and Conditions" 
                         IsChecked="{Binding AcceptTerms, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                         Margin="0,10,0,0"/>
                
            </StackPanel>
        </ScrollViewer>
        
        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                   Orientation="Horizontal" 
                   HorizontalAlignment="Right" 
                   Margin="0,20,0,0">
            <Button Content="Validate All" 
                   Command="{Binding ValidateAllCommand}" 
                   Padding="15,5" 
                   MinWidth="100"
                   Margin="0,0,10,0"/>
            <Button Content="Clear Validation" 
                   Command="{Binding ClearValidationCommand}" 
                   Padding="15,5" 
                   MinWidth="100"
                   Margin="0,0,10,0"/>
            <Button Content="Submit" 
                   Command="{Binding SubmitCommand}" 
                   Padding="15,5" 
                   MinWidth="100"
                   IsEnabled="{Binding IsValid}"/>
        </StackPanel>
    </Grid>
</UserControl>